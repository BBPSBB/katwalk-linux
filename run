#!/usr/bin/env bash
# Start katwalk-linux: the daemon (treadmill -> the OpenXR layer) plus the in-VR overlay.
# Daemon defaults do everything (publish to the layer + head-relative); no flags needed.
# Works with any OpenXR runtime (WiVRn, Monado, SteamVR-OpenXR) - the overlay appears inside
# whatever OpenXR game you launch. One-time setup (venv, udev rules, layer install) is in the
# README. Ctrl-C stops BOTH cleanly (daemon sleeps the device) before the prompt returns.
cd "$(dirname "$0")"

PY=.venv/bin/python
if [ ! -x "$PY" ]; then
  echo "No .venv found. First-time setup:"
  echo "  python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  exit 1
fi

echo "katwalk-linux: daemon + overlay starting. Web tuner: http://localhost:8770  (Ctrl-C to stop)"
"$PY" -m katwalk.daemon &
daemon=$!
"$PY" -m katwalk.overlay_xr &
overlay=$!

cleanup() {
  trap - INT TERM                              # don't re-enter while tearing down
  # Ask both to stop the clean way (daemon sleeps the device ~5s).
  kill -INT "$daemon" "$overlay" 2>/dev/null || true
  # Wait up to ~9s for a real exit; only then force-kill whatever is stuck.
  for _ in $(seq 1 90); do
    kill -0 "$daemon" 2>/dev/null || kill -0 "$overlay" 2>/dev/null || break
    sleep 0.1
  done
  kill -KILL "$daemon" "$overlay" 2>/dev/null || true
  wait 2>/dev/null || true
}
trap cleanup INT TERM
wait

{
  "jsonid": "input_profile",
  "controller_type": "katwalk_treadmill",
  "device_class": "TrackedDeviceClass_Controller",
  "resource_root": "katwalk",
  "driver_name": "katwalk",
  "input_bindingui_mode": "controller_handed",
  "should_show_binding_errors": true,
  "legacy_binding": "{katwalk}/input/katwalk_legacy_bindings.json",
  "input_source": {
    "/input/joystick": { "type": "joystick", "click": true, "order": 1 },
    "/input/trackpad": { "type": "trackpad", "order": 2 },
    "/input/trigger":  { "type": "trigger", "click": true, "order": 3 },
    "/input/a":        { "type": "button", "order": 4 }
  }
}

{
  "bindings": {
    "/actions/legacy": {
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/legacy/in/left_axis0_press"
            },
            "position": {
              "output": "/actions/legacy/in/left_axis0_value"
            }
          },
          "mode": "joystick",
          "path": "/user/treadmill/input/joystick"
        },
        {
          "inputs": {
            "position": {
              "output": "/actions/legacy/in/left_axis0_value"
            },
            "touch": {
              "output": "/actions/legacy/in/left_axis0_touch"
            }
          },
          "mode": "trackpad",
          "path": "/user/treadmill/input/trackpad"
        }
      ]
    }
  },
  "controller_type": "katwalk_treadmill",
  "description": "Maps katwalk-linux treadmill movement onto the legacy left-hand thumbstick/trackpad axis (axis0). SteamVR shadows the game's left-stick locomotion binding onto this, so walking drives movement in any game that uses standard left-stick/trackpad locomotion - no per-game setup.",
  "name": "katwalk-linux treadmill legacy locomotion bindings"
}
